```gitignore
# =========================
# Dependencies
# =========================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================
# Next.js
# =========================
.next/
out/
build/

# =========================
# Production / Deploy
# =========================
.vercel/
.netlify/
.firebase/
dist/

# =========================
# Environment Variables
# =========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# =========================
# Logs
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# =========================
# TypeScript
# =========================
*.tsbuildinfo
next-env.d.ts

# =========================
# Testing
# =========================
coverage/
playwright-report/
test-results/

# =========================
# AI / Agent / Tooling
# =========================
.claude/
.cursor/
.vscode/
.idea/

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# Firebase
# =========================
firebase-debug.log

# =========================
# Temporary Files
# =========================
*.tmp
*.temp
.cache/
.tmp/

# =========================
# Misc
# =========================
*.pem
```
